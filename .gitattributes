# Normalize line endings to LF in the repo, checkout as-is
* text=auto eol=lf

# Force these to always be LF
*.md text eol=lf
*.py text eol=lf
*.js text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.txt text eol=lf

# Binaries — don't touch
*.png binary
*.jpg binary
*.ico binary
*.svg binary
